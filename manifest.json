{
  "manifest_version": 3,
  "name": "QuickGPT Demo Interceptor",
  "version": "0.4.0",
  "description": "Proxies ChatGPT conversations to speedy-gpt.jmw.nz.",
  "host_permissions": ["https://speedy-gpt.jmw.nz/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "all_frames": true
    },
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN",
      "all_frames": true
    }
  ]
}
